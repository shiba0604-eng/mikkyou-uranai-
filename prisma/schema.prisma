generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  birthYear   Int
  birthMonth  Int
  birthDay    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  logs        FortuneLog[]
}

/// 毎朝の配信ログ
model FortuneLog {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           String   // "2026-03-23"
  birthShuku     String
  todayShuku     String
  avoidanceLevel String
  dangerScore    Int
  isRikkai       Boolean
  sentAt         DateTime @default(now())

  @@unique([userId, date])
}
