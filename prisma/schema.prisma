generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  birthYear   Int
  birthMonth  Int
  birthDay    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  logs        FortuneLog[]
  slideCredits SlideCreditAccount?
}

/// HighStakes-Slides: 書き出しクレジット（Stripe連携想定）
model SlideCreditAccount {
  id               String   @id @default(cuid())
  userId           String?  @unique
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email            String   @unique
  creditsBalance   Int      @default(0)
  creditsLifetime  Int      @default(0)
  stripeCustomerId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  exportLogs       SlideExportLog[]
}

model SlideExportLog {
  id         String   @id @default(cuid())
  accountId  String
  account    SlideCreditAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  slideCount Int
  dnaId      String
  consumed   Int      @default(1)
  createdAt  DateTime @default(now())
}

/// 毎朝の配信ログ
model FortuneLog {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           String   // "2026-03-23"
  birthShuku     String
  todayShuku     String
  avoidanceLevel String
  dangerScore    Int
  isRikkai       Boolean
  sentAt         DateTime @default(now())

  @@unique([userId, date])
}
